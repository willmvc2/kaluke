{
  "expo": {
    "name": "kaluke",
    "slug": "kaluke",
    "version": "1.0.0",
    "orientation": "landscape",
   "icon": "./assets/icon.png",
    "scheme": "kaluke",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.willmvc.kaluke"
    },

    "android": {
      "package": "com.willmvc.kaluke",
      "adaptiveIcon": {
  "foregroundImage": "./assets/icon.png",
  "backgroundColor": "#ffffff"
}
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "99a13d0c-6287-4925-b9ae-ad4dec979baa"
      }
    }
  }
}